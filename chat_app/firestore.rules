rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    function isSignedIn() {
      return request.auth != null;
    }

    function isAdmin() {
      return isSignedIn() &&
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.isAdmin == true;
    }

    function isApproved() {
      return isSignedIn() &&
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.chatApproved == true;
    }

    function isApprovedOrAdmin() {
      return isApproved() || isAdmin();
    }

    function requesterUserData() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data;
    }

    function requesterBubbleId() {
      return requesterUserData().bubbleId;
    }

    function requesterBubbleIds() {
      return requesterUserData().bubbleIds is list
        ? requesterUserData().bubbleIds
        : [];
    }

    function hasSharedBubble(targetUserData) {
      return
        (
          requesterBubbleId() is string &&
          requesterBubbleId() != '' &&
          (
            targetUserData.bubbleId == requesterBubbleId() ||
            (targetUserData.bubbleIds is list &&
              targetUserData.bubbleIds.hasAny([requesterBubbleId()]))
          )
        ) ||
        (
          requesterBubbleIds().size() > 0 &&
          (
            (targetUserData.bubbleId is string &&
              requesterBubbleIds().hasAny([targetUserData.bubbleId])) ||
            (targetUserData.bubbleIds is list &&
              targetUserData.bubbleIds.hasAny(requesterBubbleIds()))
          )
        );
    }

    function restrictedUserFieldsChanged() {
      return request.resource.data.diff(resource.data).affectedKeys().hasAny([
        'chatApproved',
        'isAdmin',
        'verificationStatus',
        'bubbleId',
        'bubbleIds'
      ]);
    }

    function isConversationParticipant(data) {
      return data.customer_id == request.auth.uid ||
        data.assigned_to == request.auth.uid ||
        (data.participants is list && request.auth.uid in data.participants);
    }

    match /users/{userId} {
      allow get: if isSignedIn() && (
        isAdmin() ||
        resource.data.isAdmin == true ||
        request.auth.uid == userId ||
        (
          isApproved() &&
          hasSharedBubble(resource.data)
        )
      );
      allow list: if isSignedIn() && (
        isAdmin() ||
        isApproved()
      );
      allow create: if isSignedIn() &&
        request.auth.uid == userId &&
        request.resource.data.chatApproved == false &&
        request.resource.data.isAdmin == false &&
        request.resource.data.verificationStatus == 'pending' &&
        request.resource.data.bubbleId == '' &&
        (
          !request.resource.data.keys().hasAny(['bubbleIds']) ||
          request.resource.data.bubbleIds.size() == 0
        );
      allow update: if isSignedIn() && (
        (
          request.auth.uid == userId &&
          !restrictedUserFieldsChanged()
        ) ||
        isAdmin()
      );
    }

    match /conversations/{conversationId} {
      allow read: if isApprovedOrAdmin() && isConversationParticipant(resource.data);
      allow create: if isApprovedOrAdmin() && (
        request.resource.data.customer_id == request.auth.uid ||
        request.resource.data.assigned_to == request.auth.uid ||
        (request.resource.data.participants is list &&
          request.auth.uid in request.resource.data.participants)
      );
      allow update, delete: if isApprovedOrAdmin() && isConversationParticipant(resource.data);

      match /messages/{messageId} {
        allow read, create: if isApprovedOrAdmin() &&
          isConversationParticipant(
            get(/databases/$(database)/documents/conversations/$(conversationId)).data
          ) &&
          (request.method != 'create' || request.resource.data.sender_ref == request.auth.uid);
        allow update, delete: if false;
      }
    }

    match /user_device_tokens/{tokenId} {
      allow read: if isSignedIn() && (
        isAdmin() ||
        resource.data.customer_ref == request.auth.uid
      );
      allow create, update: if isSignedIn() &&
        request.resource.data.customer_ref == request.auth.uid;
      allow delete: if false;
    }

    match /bubbles/{bubbleId} {
      allow read: if isSignedIn();
      allow create: if isSignedIn();
      allow update, delete: if isAdmin();
    }
  }
}
